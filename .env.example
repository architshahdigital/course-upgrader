# --- LLM provider selection ---
# One of: anthropic, gemini
COURSE_UPGRADER_LLM_PROVIDER=anthropic

# --- Anthropic Claude (default provider) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Google Gemini (alternative provider) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Search tuning ---
COURSE_UPGRADER_MAX_PER_PLATFORM=5
COURSE_UPGRADER_TIMEOUT=15
